#!/bin/bash
# Dino Generator launcher — runs the Flux server in the background and
# opens the browser to the UI. Quit via the Dock icon to stop the server.

LOGFILE="$HOME/dino_art/flux/server.log"

cd "$HOME/dino_art" || {
    osascript -e 'display alert "Dino Generator" message "~/dino_art folder not found."'
    exit 1
}

if [ ! -f venv/bin/activate ]; then
    osascript -e 'display alert "Dino Generator" message "Python venv missing at ~/dino_art/venv. Run: python3 -m venv venv && pip install -r flux/requirements.txt"'
    exit 1
fi

source venv/bin/activate

# Open the browser shortly after the server binds
( sleep 4 && open "http://localhost:8888" ) &

# Replace this shell with the python server so quitting the app kills it cleanly
exec python flux/comfyui_server.py --port 8888 >>"$LOGFILE" 2>&1
