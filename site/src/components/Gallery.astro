---
import { Image, getImage } from 'astro:assets';
import productsData from '../data/products.json';

const imageModules = import.meta.glob('../assets/gallery/**/*.{png,jpg,jpeg,webp,gif}', {
  eager: true,
  import: 'default',
});
const videoModules = import.meta.glob('../assets/gallery/**/*.{mp4,webm,mov}', {
  eager: true,
  import: 'default',
});

// Key by "<category>/<basename>" to match the relative path stored in products.json.
const byFilename = new Map();
for (const [path, mod] of Object.entries({ ...imageModules, ...videoModules })) {
  const parts = path.split('/');
  const relPath = parts.slice(-2).join('/');
  byFilename.set(relPath, mod);
}

const SITE = 'https://jurassinkart.com';
const ETSY_SHOP_URL = 'https://www.etsy.com/shop/Jurassinkart';

const products = await Promise.all(
  productsData.map(async (p) => {
    const asset = byFilename.get(p.filename);
    if (!asset) return null;

    if (p.type === 'video') {
      return { ...p, src: asset, isVideo: true };
    }

    // Build a large WebP for the lightbox + the metadata for the thumbnail.
    const full = await getImage({
      src: asset,
      format: 'webp',
      width: Math.min(p.width, 2400),
      quality: 88,
    });

    return {
      ...p,
      asset,
      isVideo: false,
      fullSrc: full.src,
      fullWidth: full.attributes?.width || p.width,
      fullHeight: full.attributes?.height || p.height,
    };
  })
).then((r) => r.filter(Boolean));

const imageProducts = products.filter((p) => !p.isVideo);

const itemListSchema = {
  '@context': 'https://schema.org',
  '@type': 'ItemList',
  name: 'Jurassinkart Featured Paleoart Gallery',
  itemListElement: imageProducts.map((p, i) => ({
    '@type': 'ListItem',
    position: i + 1,
    item: {
      '@type': 'VisualArtwork',
      '@id': `${SITE}/#${p.filename}`,
      name: p.title,
      description: p.description,
      keywords: p.keywords.join(', '),
      artform: 'Digital paleoart illustration',
      artMedium: 'Digital print',
      genre: 'Paleoart',
      creator: { '@type': 'Organization', name: 'Jurassinkart' },
      copyrightHolder: { '@type': 'Organization', name: 'Jurassinkart' },
      image: {
        '@type': 'ImageObject',
        contentUrl: `${SITE}${p.fullSrc}`,
        url: `${SITE}${p.fullSrc}`,
        width: p.fullWidth,
        height: p.fullHeight,
        caption: p.alt,
        description: p.description,
        keywords: p.keywords.join(', '),
        representativeOfPage: i === 0,
        license: `${SITE}/`,
        acquireLicensePage: ETSY_SHOP_URL,
        creditText: 'Jurassinkart',
        creator: { '@type': 'Organization', name: 'Jurassinkart' },
        copyrightNotice: '© Jurassinkart',
      },
      about: {
        '@type': 'Thing',
        name: p.scientific_name,
        description: `${p.scientific_name} — ${p.era}`,
      },
      offers: {
        '@type': 'Offer',
        url: ETSY_SHOP_URL,
        availability: 'https://schema.org/InStock',
        priceCurrency: 'USD',
        seller: { '@type': 'Organization', name: 'Jurassinkart' },
      },
    },
  })),
};
---
<link rel="stylesheet" href="https://unpkg.com/photoswipe@5.4.4/dist/photoswipe.css" />
<section class="gallery">
  <h2 class="gallery-title">Featured Works</h2>
  <p class="gallery-sub">Click any piece to step inside.</p>

  <div class="gallery-filters" role="tablist" aria-label="Filter by category">
    <button class="filter-btn is-active" data-filter="all" role="tab" aria-selected="true">All</button>
    <button class="filter-btn" data-filter="predators" role="tab">Predators</button>
    <button class="filter-btn" data-filter="herbivores" role="tab">Herbivores</button>
    <button class="filter-btn" data-filter="aerial" role="tab">Aerial</button>
    <button class="filter-btn" data-filter="marine" role="tab">Marine</button>
    <button class="filter-btn" data-filter="flora_arthropods" role="tab">Flora &amp; Arthropods</button>
  </div>

  {products.length > 0 ? (
    <div class="gallery-grid" id="masonry-grid">
      {products.map((product) => (
        product.isVideo ? (
          <figure class="gallery-card video-card" data-category={product.category}>
            <video
              src={product.src}
              autoplay
              muted
              loop
              playsinline
              preload="metadata"
              class="product-image"
              aria-label={product.alt}
            ></video>
            <figcaption class="card-overlay">
              <span class="card-title">{product.title}</span>
              <span class="card-cue">Available as a print &nbsp;→</span>
            </figcaption>
          </figure>
        ) : (
          <figure class="gallery-figure" data-category={product.category}>
            <a
              class="gallery-card"
              href={product.fullSrc}
              data-pswp-width={product.fullWidth}
              data-pswp-height={product.fullHeight}
              data-title={product.title}
              data-alt={product.alt}
              data-scientific={product.scientific_name}
              data-era={product.era}
              target="_blank"
              rel="noopener"
              aria-label={`Open ${product.title} — ${product.scientific_name}`}
            >
              <Image
                src={product.asset}
                alt={product.alt}
                widths={[400, 800, 1200]}
                sizes="(max-width: 600px) 100vw, (max-width: 900px) 50vw, 33vw"
                formats={['avif', 'webp']}
                loading="lazy"
                decoding="async"
                class="product-image"
              />
              <figcaption class="card-overlay">
                <span class="card-title">{product.title}</span>
                <span class="card-cue">View &amp; shop &nbsp;→</span>
              </figcaption>
            </a>
            <figcaption class="visually-hidden">
              {product.title} — {product.scientific_name}, {product.era}. {product.description}
            </figcaption>
          </figure>
        )
      ))}
    </div>
  ) : (
    <p class="empty-state">Curating featured posters and canvas works — check back soon.</p>
  )}
</section>

<script type="application/ld+json" set:html={JSON.stringify(itemListSchema)} />

<script type="module" is:inline>
  import Masonry from 'https://esm.sh/masonry-layout@4.2.2';
  import imagesLoaded from 'https://esm.sh/imagesloaded@5.0.0';
  import PhotoSwipeLightbox from 'https://esm.sh/photoswipe@5.4.4/lightbox';

  function initGallery() {
    const grid = document.getElementById('masonry-grid');
    if (!grid) return;

    const masonry = new Masonry(grid, {
      itemSelector: '.gallery-figure, .video-card',
      columnWidth: '.gallery-figure, .video-card',
      percentPosition: true,
      gutter: 20,
      transitionDuration: '0.3s',
    });

    imagesLoaded(grid).on('progress', () => masonry.layout());

    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = grid.querySelectorAll('.gallery-figure, .video-card');
    filterBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        const filter = btn.dataset.filter;
        filterBtns.forEach(b => {
          const active = b === btn;
          b.classList.toggle('is-active', active);
          b.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        cards.forEach(c => {
          const match = filter === 'all' || c.dataset.category === filter;
          c.classList.toggle('is-hidden', !match);
        });
        masonry.layout();
      });
    });

    const lightbox = new PhotoSwipeLightbox({
      gallery: '#masonry-grid',
      children: '.gallery-figure:not(.is-hidden) > a.gallery-card',
      pswpModule: () => import('https://esm.sh/photoswipe@5.4.4'),
      bgOpacity: 0.96,
      showHideAnimationType: 'fade',
    });

    lightbox.on('uiRegister', () => {
      lightbox.pswp.ui.registerElement({
        name: 'jungle-caption',
        order: 9,
        isButton: false,
        appendTo: 'root',
        html: '',
        onInit: (el, pswp) => {
          el.classList.add('pswp__jungle-caption');
          const ETSY_SHOP_URL = 'https://www.etsy.com/shop/Jurassinkart';
          const update = () => {
            const slideEl = pswp.currSlide?.data?.element;
            if (!slideEl) return;
            const title = slideEl.dataset.title || '';
            const sci = slideEl.dataset.scientific || '';
            const era = slideEl.dataset.era || '';
            el.innerHTML = `
              <div class="pswp__jungle-caption-inner">
                <h3>${title}</h3>
                <p class="pswp__sci">${sci}${era ? ` — ${era}` : ''}</p>
                <a class="pswp__buy-btn" href="${ETSY_SHOP_URL}" target="_blank" rel="noopener">Shop the Collection →</a>
              </div>
            `;
          };
          pswp.on('change', update);
          pswp.on('afterInit', update);
        },
      });
    });

    lightbox.init();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initGallery);
  } else {
    initGallery();
  }
</script>

<style is:global>
  .gallery {
    padding: 4rem 1rem 6rem;
    max-width: 1280px;
    margin: 0 auto;
    position: relative;
  }

  .gallery-title {
    text-align: center;
    font-family: 'Cinzel', 'Georgia', serif;
    font-weight: 500;
    font-size: clamp(1.6rem, 3vw, 2.4rem);
    letter-spacing: 0.16em;
    color: #e6dccb;
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    text-shadow: 0 2px 18px rgba(0,0,0,0.6);
  }

  .gallery-sub {
    text-align: center;
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-style: italic;
    font-size: 1.05rem;
    color: #a89e89;
    margin-bottom: 1.5rem;
    letter-spacing: 0.04em;
  }

  .gallery-filters {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px;
    margin: 0 auto 2.5rem;
    padding: 0 1rem;
  }
  .filter-btn {
    background: transparent;
    color: #a89e89;
    border: 1px solid rgba(193, 165, 110, 0.18);
    padding: 8px 18px;
    font-family: 'Cinzel', 'Georgia', serif;
    font-size: 0.78rem;
    font-weight: 500;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    border-radius: 999px;
    cursor: pointer;
    transition: color 0.25s ease, border-color 0.25s ease,
                background 0.25s ease, transform 0.25s ease;
  }
  .filter-btn:hover {
    color: #e6dccb;
    border-color: rgba(193, 165, 110, 0.5);
    transform: translateY(-1px);
  }
  .filter-btn.is-active {
    color: #f5ecd9;
    border-color: rgba(193, 165, 110, 0.7);
    background: rgba(193, 165, 110, 0.08);
    box-shadow: 0 0 0 1px rgba(193, 165, 110, 0.25),
                0 6px 16px rgba(0,0,0,0.3);
  }
  .gallery-figure.is-hidden,
  .video-card.is-hidden {
    display: none !important;
  }

  .gallery-grid {
    margin: 0 auto;
  }

  .gallery-figure,
  .video-card {
    width: calc(33.333% - 14px);
    margin: 0 0 20px 0;
    padding: 0;
  }

  .gallery-card {
    display: block;
    width: 100%;
    border-radius: 14px;
    overflow: hidden;
    background: rgba(8, 12, 18, 0.4);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.55);
    text-decoration: none;
    color: inherit;
    position: relative;
    cursor: zoom-in;
    transition: transform 0.5s cubic-bezier(0.2, 0.7, 0.2, 1),
                box-shadow 0.5s ease;
  }
  .video-card {
    border-radius: 14px;
    overflow: hidden;
    background: rgba(8, 12, 18, 0.4);
    box-shadow: 0 14px 40px rgba(0, 0, 0, 0.55);
    position: relative;
  }

  .gallery-card:hover {
    transform: translateY(-3px);
    box-shadow: 0 22px 50px rgba(0, 0, 0, 0.75),
                0 0 0 1px rgba(193, 165, 110, 0.25);
  }

  .product-image {
    width: 100%;
    height: auto;
    display: block;
    transition: transform 0.7s cubic-bezier(0.2, 0.7, 0.2, 1),
                filter 0.7s ease;
    filter: saturate(1.05) contrast(1.04);
  }

  .gallery-card:hover .product-image {
    transform: scale(1.04);
    filter: saturate(1.15) contrast(1.08) brightness(1.06);
  }

  .card-overlay {
    position: absolute;
    inset: auto 0 0 0;
    padding: 80px 18px 16px;
    background: linear-gradient(
      to top,
      rgba(0, 0, 0, 0.85) 0%,
      rgba(0, 0, 0, 0.55) 55%,
      rgba(0, 0, 0, 0) 100%
    );
    display: flex;
    flex-direction: column;
    gap: 4px;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }

  .gallery-card:hover .card-overlay,
  .video-card:hover .card-overlay {
    opacity: 1;
  }

  .card-title {
    font-family: 'Cinzel', 'Georgia', serif;
    font-size: 1rem;
    letter-spacing: 0.08em;
    color: #f5ecd9;
    text-transform: uppercase;
    text-shadow: 0 2px 10px rgba(0,0,0,0.9);
  }

  .card-cue {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-style: italic;
    font-size: 0.95rem;
    color: #c9b988;
    letter-spacing: 0.04em;
  }

  .visually-hidden {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  @media (max-width: 900px) {
    .gallery-figure,
    .video-card {
      width: calc(50% - 10px);
    }
  }

  @media (max-width: 600px) {
    .gallery-figure,
    .video-card {
      width: 100%;
    }
  }

  .empty-state {
    text-align: center;
    color: #d4c9b6;
    font-size: 1rem;
    padding: 2rem 1rem;
  }

  /* ── PhotoSwipe jungle caption + Buy CTA ── */
  .pswp__jungle-caption {
    position: absolute;
    left: 0;
    right: 0;
    bottom: 0;
    padding: 28px 24px 36px;
    background: linear-gradient(
      to top,
      rgba(8, 12, 18, 0.92) 0%,
      rgba(8, 12, 18, 0.6) 70%,
      rgba(8, 12, 18, 0) 100%
    );
    text-align: center;
    pointer-events: none;
    z-index: 10;
  }
  .pswp__jungle-caption-inner {
    max-width: 720px;
    margin: 0 auto;
    pointer-events: auto;
  }
  .pswp__jungle-caption-inner h3 {
    font-family: 'Cinzel', 'Georgia', serif;
    font-size: 1.35rem;
    letter-spacing: 0.14em;
    color: #f5ecd9;
    text-transform: uppercase;
    margin: 0 0 6px;
    text-shadow: 0 2px 12px rgba(0,0,0,0.9);
  }
  .pswp__sci {
    font-family: 'Cormorant Garamond', 'Georgia', serif;
    font-style: italic;
    color: #c9b988;
    font-size: 1rem;
    margin: 0 0 14px;
    letter-spacing: 0.04em;
  }
  .pswp__buy-btn {
    display: inline-block;
    padding: 12px 28px;
    background: linear-gradient(180deg, #c2652a 0%, #a8531e 100%);
    color: #fff;
    text-decoration: none;
    border-radius: 4px;
    font-family: 'Cinzel', 'Georgia', serif;
    font-size: 0.85rem;
    font-weight: 500;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    box-shadow: 0 8px 24px rgba(0,0,0,0.5),
                inset 0 1px 0 rgba(255,255,255,0.15);
    transition: transform 0.25s ease, box-shadow 0.25s ease, background 0.25s ease;
  }
  .pswp__buy-btn:hover {
    background: linear-gradient(180deg, #d4762e 0%, #b85b1f 100%);
    transform: translateY(-2px);
    box-shadow: 0 12px 30px rgba(0,0,0,0.6),
                inset 0 1px 0 rgba(255,255,255,0.2);
  }
</style>
