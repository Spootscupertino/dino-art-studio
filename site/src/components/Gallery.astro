---
import productsData from '../data/products.json';

let products = productsData;
---
<section class="gallery">
  <h2>Featured Works</h2>
  <div class="gallery-grid">
    {products.length > 0 ? (
      products.map(product => (
        <div class="gallery-card">
          {product.image ? (
            <img
              src={product.image}
              alt={product.title}
              loading="lazy"
              class="product-image"
            />
          ) : (
            <div class="no-image">No Image</div>
          )}
        </div>
      ))
    ) : (
      <p class="empty-state">Curating featured posters and canvas works — check back soon.</p>
    )}
  </div>
</section>

<style>
  .gallery {
    padding: 2rem 0;
  }
  
  .gallery h2 {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
    gap: 2rem;
    padding: 0 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }

  .gallery-card {
    display: flex;
    flex-direction: column;
    justify-content: flex-start;
    align-items: stretch;
    border-radius: 16px;
    overflow: hidden;
    background: rgba(0, 0, 0, 0.2);
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.5);
    transition: box-shadow 0.3s ease;
    height: 100%;
    min-height: 340px;
    max-height: 420px;
  }

  .gallery-card:hover {
    box-shadow: 0 18px 40px rgba(0,0,0,0.7);
  }

  .product-image {
    width: 100%;
    height: 340px;
    aspect-ratio: 4 / 5;
    object-fit: cover;
    object-position: center;
    display: block;
    background: #222;
    border-radius: 12px 12px 0 0;
    transition: transform 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275), filter 0.4s ease;
    filter: saturate(1.05) contrast(1.05);
  }

  .gallery-card:hover .product-image {
    transform: scale(1.03);
    filter: saturate(1.1) contrast(1.1) brightness(1.1);
  }

  @media (max-width: 600px) {
    .gallery-grid {
      grid-template-columns: 1fr;
      gap: 1.2rem;
    }
    .gallery-card {
      min-height: 220px;
      max-height: 320px;
    }
    .product-image {
      height: 220px;
    }
  }

  .no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #333;
    color: #999;
  }

  .empty-state {
    grid-column: 1 / -1;
    text-align: center;
    color: #d4c9b6;
    font-size: 1rem;
    letter-spacing: 0.02em;
    padding: 2rem 1rem;
  }

</style>
