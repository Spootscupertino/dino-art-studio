---
import { GET } from '../pages/api/printify.js';

let products = [];
try {
  // Call the endpoint function directly so we don't have networking/port issues
  const response = await GET();
  if (response.ok) {
    products = await response.json();
  }
} catch (e) {
  console.error('Failed to load products from API route', e);
}
---
<section class="gallery">
  <h2>Featured Works</h2>
  <div class="gallery-grid">
    {products.length > 0 ? (
      products.map(product => (
        <div class="gallery-card">
          {product.image ? (
            <img src={product.image} alt={product.title} loading="lazy" />
          ) : (
            <div class="no-image">No Image</div>
          )}
          <div class="card-overlay">
            <h3>{product.title}</h3>
          </div>
        </div>
      ))
    ) : (
      <p>Loading gallery items...</p>
    )}
  </div>
</section>

<style>
  .gallery {
    padding: 2rem 0;
  }
  
  .gallery h2 {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  
  /* GRID / RESPONSIVE (Task 6) */
  .gallery-grid {
    display: grid;
    grid-template-columns: repeat(1, 1fr);
    gap: 2rem;
    padding: 0 1rem;
    max-width: 1200px;
    margin: 0 auto;
  }
  
  @media (min-width: 600px) {
    .gallery-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (min-width: 900px) {
    .gallery-grid { grid-template-columns: repeat(3, 1fr); }
  }
  @media (min-width: 1200px) {
    .gallery-grid { grid-template-columns: repeat(4, 1fr); }
  }

  /* NORMALIZE CARD SIZE & HOVER EFFECT (Tasks 3 & 5) */
  .gallery-card {
    position: relative;
    aspect-ratio: 4 / 5;
    border-radius: 12px;
    overflow: hidden;
    background: #1a1a1a;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
    cursor: pointer;
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }
  
  .gallery-card:hover {
    transform: scale(1.03);
    box-shadow: 0 8px 25px rgba(0,0,0,0.5);
  }

  /* FIX IMAGE BEHAVIOR (Task 2) */
  .gallery-card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  
  .gallery-card:hover img {
    transform: scale(1.05); /* Subtle inner zoom on hover */
  }

  .no-image {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background: #333;
    color: #999;
  }

  /* CLEAN TITLE STYLING (Task 4) */
  .card-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 100%;
    padding: 3rem 1.25rem 1.25rem;
    background: linear-gradient(to top, rgba(0,0,0,0.95) 0%, rgba(0,0,0,0.5) 50%, rgba(0,0,0,0) 100%);
    color: white;
    pointer-events: none; /* Let clicks pass through to card */
  }

  .card-overlay h3 {
    margin: 0;
    font-size: 1.15rem;
    font-weight: 500;
    line-height: 1.4;
    /* Limit to 2 lines with ellipsis */
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
    text-overflow: ellipsis;
    text-shadow: 0 2px 4px rgba(0,0,0,0.6);
  }
</style>
